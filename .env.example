# Admin wallet private key (for deployment and admin operations)
# NEVER commit .env or share this key
PRIVATE_KEY=your_private_key_here

# Mumbai Testnet RPC
MUMBAI_RPC_URL=https://rpc-mumbai.maticvigil.com/

# Sepolia Testnet RPC (optional)
# SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY

# Block explorer API keys (for contract verification)
# Get from https://polygonscan.com/myapikey
POLYGONSCAN_API_KEY=your_polygonscan_api_key

# Get from https://etherscan.io/myapikey (for Sepolia)
# ETHERSCAN_API_KEY=your_etherscan_api_key
