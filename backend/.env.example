# MongoDB
MONGODB_URI=mongodb://localhost:27017
DB_NAME=crypto_world_bank

# Server
PORT=3001
JWT_SECRET=your_jwt_secret_change_in_production

# Blockchain (EVM - Polygon Mumbai / Sepolia)
# RPC URL - used for reading contract state
BLOCKCHAIN_RPC_URL=https://rpc-mumbai.maticvigil.com/
# Or: MUMBAI_RPC_URL=https://rpc-mumbai.maticvigil.com/

# Contract address - set after deploying WorldBankReserve
# Run: npm run deploy:mumbai (from project root) then copy address from deployment-info.json
CONTRACT_ADDRESS=
