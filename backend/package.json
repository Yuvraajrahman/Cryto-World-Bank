{
  "name": "@cwb/backend",
  "version": "2.0.0",
  "private": true,
  "description": "Crypto World Bank REST API and indexer",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
