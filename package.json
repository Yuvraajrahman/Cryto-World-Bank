{
  "name": "crypto-world-bank",
  "version": "2.0.0",
  "private": true,
  "description": "Decentralized Crypto World Bank — a four-tier blockchain lending platform",
  "scripts": {
    "compile": "hardhat compile",
    "test:contracts": "hardhat test",
    "node:chain": "hardhat node",
    "deploy:local": "hardhat run scripts/deploy.ts --network localhost",
    "deploy:sepolia": "hardhat run scripts/deploy.ts --network sepolia",
    "deploy:amoy": "hardhat run scripts/deploy.ts --network amoy",
    "frontend:dev": "cd frontend && npm run dev",
    "frontend:build": "cd frontend && npm run build",
    "backend:dev": "cd backend && npm run dev",
    "backend:build": "cd backend && npm run build",
    "ml:dev": "cd ml-service && uvicorn app.main:app --reload --port 8000",
    "dev": "sh -c 'for p in 4000 5173 5174; do lsof -ti :$p | xargs kill -9 2>/dev/null || true; done; concurrently -n frontend,backend -c blue,green \"npm run frontend:dev\" \"npm run backend:dev\"'"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^3.0.8",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@types/node": "^20.11.0",
    "chai": "^4.4.1",
    "concurrently": "^9.0.1",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.2",
    "hardhat": "^2.22.10",
    "solidity-coverage": "^0.8.12",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.2"
  }
}
